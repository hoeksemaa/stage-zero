{
  "regions": {
    "north_america": {
      "name": "North America",
      "description": "US and Canada. FDA regulatory zone. Largest single medtech market globally."
    },
    "latin_america": {
      "name": "Latin America & Caribbean",
      "description": "Mexico through Argentina, plus Caribbean nations. Key regulators: ANVISA (Brazil), COFEPRIS (Mexico). Companies typically enter Brazil and Mexico first."
    },
    "europe": {
      "name": "Europe",
      "description": "EU members, UK, Switzerland, Norway, Iceland, Balkans, Turkey, Russia, microstates. CE-mark / UKCA regulatory zone. Turkey included due to EU-aligned regulatory framework (TITCK)."
    },
    "mena": {
      "name": "Middle East & North Africa",
      "description": "Gulf states, Levant, North Africa (Morocco through Egypt). Government and royal hospital purchasing systems, high-end private sector. Often entered as a single commercial unit."
    },
    "sub_saharan_africa": {
      "name": "Sub-Saharan Africa",
      "description": "Everything south of the Sahara. Distinct from MENA in infrastructure, reimbursement (mostly out-of-pocket or donor-funded), and regulatory fragmentation."
    },
    "asia_pacific": {
      "name": "Asia-Pacific",
      "description": "Japan, China, South Korea, Taiwan, India, ASEAN, Australia, NZ, Pacific Islands, Central Asia. Major regulators: PMDA (Japan), NMPA (China), TGA (Australia). Internally heterogeneous — may warrant subdivision in future."
    }
  },
